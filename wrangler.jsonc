{
  // Cloudflare Workers static-assets deploy for the save-the-date site.
  // Serves only the built ./dist folder — keeps node_modules (workerd, etc.)
  // out of the upload, which otherwise trips the 25 MiB per-file asset limit.
  // Build command in the Cloudflare project must be: npm run build
  "name": "save-the-date-12-09-26",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist"
  }
}
